# Database Configuration
DATASOURCE_URL=jdbc:postgresql://localhost:5432/Mobile_ecommerce
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=123456789

# Server Configuration
SERVER_PORT=8000

# JPA Configuration
JPA_HIBERNATE_DDL_AUTO=none
JPA_SHOW_SQL=true

# Mail Configuration (Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=example@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Mail SMTP Configuration
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
